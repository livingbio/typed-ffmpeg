{
  "description": "Core runtime for typed-ffmpeg TypeScript bindings",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "browser": "./dist/browser/index.browser.js",
      "import": "./dist/esm/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@typed-ffmpeg/core",
  "scripts": {
    "build": "tsc && tsc --project tsconfig.esm.json && tsc --project tsconfig.browser.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "types": "dist/index.d.ts",
  "version": "0.1.0"
}
